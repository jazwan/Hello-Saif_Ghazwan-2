-- وظيفة لتحديث النص في الواجهة
local function updateDisplay()
	counterLabel.Text = tostring(attackRange)
end

-- أزرار التحكم بالمدى
minusButton.MouseButton1Click:Connect(function()
	if attackRange > MIN_RANGE then
		attackRange = attackRange - 1
		updateDisplay()
	end
end)

plusButton.MouseButton1Click:Connect(function()
	if attackRange < MAX_RANGE then
		attackRange = attackRange + 1
		updateDisplay()
	end
end)

-- ============================================
-- 2. كود الهيد سيف الأساسي والفعال
-- ============================================
local function getSwordPart(sword)
    if not sword then return nil end
    return sword:FindFirstChild("Handle") or sword:FindFirstChild("Blade") or sword:FindFirstChildOfClass("Part") or sword:FindFirstChildOfClass("MeshPart")
end

RunService.RenderStepped:Connect(function()
    if not _G.SuperSwordReach then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local sword = character:FindFirstChildOfClass("Tool")
    local myRoot = character:FindFirstChild("HumanoidRootPart")
    
    if sword and myRoot then
        local swordPart = getSwordPart(sword)
        if swordPart then
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local enemyCharacter = player.Character
                    local enemyRoot = enemyCharacter:FindFirstChild("HumanoidRootPart")
                    local enemyHumanoid = enemyCharacter:FindFirstChildOfClass("Humanoid")
                    
                    if enemyRoot and enemyHumanoid and enemyHumanoid.Health > 0 then
                        local distance = (myRoot.Position - enemyRoot.Position).Magnitude
                        
                        -- استخدام الـ attackRange المتغير بناءً على العداد
                        if distance <= attackRange then
                            local originalCFrame = myRoot.CFrame 
                            myRoot.CFrame = enemyRoot.CFrame * CFrame.new(0, 0, 2) 
                            
                            pcall(function()
                                firetouchinterest(swordPart, enemyRoot, 0)
                                firetouchinterest(swordPart, enemyRoot, 1)
                            end)
                            
                            myRoot.CFrame = originalCFrame
                        end
                    end
                end
            end
        end
    end
end)
